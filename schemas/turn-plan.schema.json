{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://persona-router.local/schemas/turn-plan.schema.json",
  "title": "Persona Router Turn Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "round_index", "topic", "items"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.1\\.0$"
    },
    "round_index": {
      "type": "integer",
      "minimum": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "allow_cross_questions": {
      "type": "boolean",
      "default": true
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["agent_id", "trigger"],
        "properties": {
          "agent_id": {
            "$ref": "#/$defs/agent_id"
          },
          "trigger": {
            "type": "string",
            "enum": ["active", "mentioned", "moderator", "manual"]
          }
        }
      }
    }
  },
  "$defs": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,63}$"
    }
  }
}
