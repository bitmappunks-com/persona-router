# Copy to `.env` and fill in. `.env` is gitignored.
#
# Pick ONE provider. Without a key the server runs in deterministic mock mode.

# DeepSeek (default base_url + model when DEEPSEEK_API_KEY is set)
DEEPSEEK_API_KEY=

# OpenAI (https://api.openai.com/v1)
# OPENAI_API_KEY=

# Optional overrides
# PERSONA_ROUTER_MODEL=deepseek-chat
# PERSONA_ROUTER_TEMPERATURE=0.4
# PERSONA_ROUTER_MAX_TOKENS=1024
# PERSONA_ROUTER_BASE_URL=               # fully custom OpenAI-compatible endpoint
